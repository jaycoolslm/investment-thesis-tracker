{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/install_deps.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "product-management@knowledge-work-plugins": true,
    "engineering@knowledge-work-plugins": true,
    "design@knowledge-work-plugins": true,
    "marketing@knowledge-work-plugins": true
  }
}
