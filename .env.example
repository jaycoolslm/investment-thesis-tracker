# Database
DATABASE_URL=postgresql://thesis:thesis@localhost:5432/thesis_tracker

# App
PORT=3001
NODE_ENV=development

# OpenAI / Codex SDK
# OPENAI_API_KEY=sk-...

# Azure OpenAI (alternative to OPENAI_API_KEY)
# AZURE_OPENAI_ENDPOINT=https://<your-instance>.openai.azure.com/
# AZURE_OPENAI_API_KEY=<key>

# Weekly Monitoring
# MONITORING_CRON_SCHEDULE=0 6 * * 1
# MONITORING_CONCURRENCY=10

# Data Provider (optional). When set, the monitoring page shows a provider
# health card fed by GET /api/provider/health (proxied to <url>/health).
# Leave unset to hide the card entirely.
# DATA_PROVIDER_URL=http://localhost:3002

